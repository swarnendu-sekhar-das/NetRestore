# ============================================================================
# Git Ignore Configuration for NetRestore Project
# ============================================================================
# This file specifies intentionally untracked files that Git should ignore.
# Patterns are grouped by category for maintainability.
# ============================================================================

# ---------------------------------------------------------------------------
# Python Build Artifacts
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ---------------------------------------------------------------------------
# Virtual Environments
# ---------------------------------------------------------------------------
.env          # Local environment variables (contains secrets)
.venv
env/
venv/
ENV/
.ci-env/      # CI/CD temporary environment

# ---------------------------------------------------------------------------
# Jupyter Notebook Checkpoints
# ---------------------------------------------------------------------------
.ipynb_checkpoints

# ---------------------------------------------------------------------------
# Operating System Artifacts
# ---------------------------------------------------------------------------
.DS_Store     # macOS
Thumbs.db     # Windows

# ---------------------------------------------------------------------------
# Project-Specific Artifacts
# ---------------------------------------------------------------------------
api.txt       # API keys (should be in .env)
data/llm_generated_sops/*.pdf  # Ignore the 675 generated PDFs (prevent repo bloat)
!chroma_db/   # DO NOT ignore the database! We need it for Streamlit Cloud deployment.

# ---------------------------------------------------------------------------
# DevOps Security Exclusions
# ---------------------------------------------------------------------------
vault/        # HashiCorp Vault secrets
*.pem         # Private keys
*.key         # Key files
*.crt         # Certificates
*.tfstate     # Terraform state files
*.tfstate.backup
.terraform/

# ---------------------------------------------------------------------------
# Development Artifacts (not for production repo)
# ---------------------------------------------------------------------------
scratch/              # Debug/scratch scripts
evaluation_results.json  # Generated at runtime by evaluate.py
