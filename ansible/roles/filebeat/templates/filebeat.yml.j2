# Filebeat Configuration for Telecom RAG ELK Integration
# This template is deployed by the Ansible 'filebeat' role.
# Variables like {{ logstash_host }} are injected from the playbook vars.

filebeat.inputs:
  # Read Docker container log files (JSON format)
  - type: container
    paths:
      - /var/lib/docker/containers/*/*.log
    processors:
      - add_docker_metadata:
          host: "unix:///var/run/docker.sock"
      - decode_json_fields:
          fields: ["message"]
          target: ""
          overwrite_keys: true

  # Also read any direct application logs if running outside Docker
  - type: log
    enabled: true
    paths:
      - /var/log/telecom-rag/*.log
    json.keys_under_root: true
    json.overwrite_keys: true

# Ship logs to Logstash for filtering/enrichment
output.logstash:
  hosts: ["{{ logstash_host | default('localhost') }}:5044"]
  # If Logstash is unavailable, buffer logs locally and retry
  bulk_max_size: 2048
  timeout: 30s

# Logging configuration for Filebeat itself
logging.level: info
logging.to_files: true
logging.files:
  path: /var/log/filebeat
  name: filebeat
  keepfiles: 7
  permissions: 0644
