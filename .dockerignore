# ============================================================================
# Docker Ignore Configuration for NetRestore Project
# ============================================================================
# This file specifies files and directories to exclude from Docker build context.
# Excluding unnecessary files reduces build time and image size.
# ============================================================================

# ---------------------------------------------------------------------------
# Python Virtual Environments (1.5GB+ - NEVER include in Docker context)
# ---------------------------------------------------------------------------
.venv/
.ci-env/
**/__pycache__/
**/*.pyc
**/*.pyo
*.egg-info/

# ---------------------------------------------------------------------------
# Local Vector Database (rebuilt inside container on first start)
# ---------------------------------------------------------------------------
chroma_db/

# ---------------------------------------------------------------------------
# Git History (not needed in production image)
# ---------------------------------------------------------------------------
.git/
.gitignore

# ---------------------------------------------------------------------------
# Development and Test Artifacts
# ---------------------------------------------------------------------------
.pytest_cache/
notebooks/*.ipynb
scratch/

# ---------------------------------------------------------------------------
# Operating System Artifacts
# ---------------------------------------------------------------------------
.DS_Store     # macOS
Thumbs.db     # Windows

# ---------------------------------------------------------------------------
# Security: Local Environment Files (secrets must not be baked into image)
# ---------------------------------------------------------------------------
.env

# ---------------------------------------------------------------------------
# Editor and IDE Configuration
# ---------------------------------------------------------------------------
.vscode/
.idea/
